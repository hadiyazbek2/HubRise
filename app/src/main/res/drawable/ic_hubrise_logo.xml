<?xml version="1.0" encoding="utf-8"?>
<!-- HubRise icon for use inside the app (light backgrounds). Blue ring + bars. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="80dp"
    android:height="80dp"
    android:viewportWidth="100"
    android:viewportHeight="100">

    <!-- Blue circle ring -->
    <path
        android:fillColor="#1A73E8"
        android:fillType="evenOdd"
        android:pathData="
          M 12,62 A 38,38 0 1 0 88,62 A 38,38 0 1 0 12,62 Z
          M 19,62 A 31,31 0 1 0 81,62 A 31,31 0 1 0 19,62 Z" />

    <!-- Left bar – short, light blue -->
    <path
        android:fillColor="#90CAF9"
        android:pathData="M 31,87 L 31,70 Q 31,67 34,67 L 38,67 Q 41,67 41,70 L 41,87 Z" />

    <!-- Middle bar – medium, blue -->
    <path
        android:fillColor="#1A73E8"
        android:pathData="M 46,87 L 46,56 Q 46,53 49,53 L 53,53 Q 56,53 56,56 L 56,87 Z" />

    <!-- Right bar – tall, orange (breaks above ring) -->
    <path
        android:fillColor="#F4A017"
        android:pathData="M 61,87 L 61,34 Q 61,31 64,31 L 68,31 Q 71,31 71,34 L 71,87 Z" />

</vector>
