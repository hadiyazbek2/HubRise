<?xml version="1.0" encoding="utf-8"?>
<!--
  HubRise launcher icon foreground (108×108 dp, safe zone 72×72 centred at 18,18).
  White ring + 3 rising bars (light-blue / white / orange).
  Orange bar intentionally breaks out of the ring to the top.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- White circle ring (even-odd: outer minus inner) -->
    <path
        android:fillColor="#FFFFFF"
        android:fillType="evenOdd"
        android:pathData="
          M 19,67 A 35,35 0 1 0 89,67 A 35,35 0 1 0 19,67 Z
          M 25,67 A 29,29 0 1 0 83,67 A 29,29 0 1 0 25,67 Z" />

    <!-- Left bar – short, light blue -->
    <path
        android:fillColor="#BFDBFE"
        android:pathData="M 36,89 L 36,74 Q 36,71 39,71 L 42,71 Q 45,71 45,74 L 45,89 Z" />

    <!-- Middle bar – medium, white -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 49.5,89 L 49.5,62 Q 49.5,59 52.5,59 L 55.5,59 Q 58.5,59 58.5,62 L 58.5,89 Z" />

    <!-- Right bar – tall, orange (breaks above ring) -->
    <path
        android:fillColor="#F4A017"
        android:pathData="M 63,89 L 63,42 Q 63,39 66,39 L 69,39 Q 72,39 72,42 L 72,89 Z" />

</vector>
