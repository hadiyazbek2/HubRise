<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_screen">

    <!-- Toolbar with search bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        android:background="@color/bg_card"
        android:elevation="2dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_back_arrow"
            android:padding="8dp"
            android:contentDescription="Back"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <EditText
            android:id="@+id/et_search"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:background="@drawable/search_bar_bg"
            android:paddingHorizontal="14dp"
            android:hint="Search people, hubs, posts..."
            android:textColorHint="@color/text_secondary"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:inputType="text"
            android:imeOptions="actionSearch"
            android:maxLines="1"
            android:singleLine="true" />

    </LinearLayout>

    <!-- Tab bar -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tab_layout"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="@color/bg_card"
        app:tabTextColor="@color/text_secondary"
        app:tabSelectedTextColor="@color/blue_primary"
        app:tabIndicatorColor="@color/blue_primary"
        app:tabIndicatorHeight="3dp"
        app:tabMode="scrollable"
        app:tabTextAppearance="@android:style/TextAppearance.Widget.TabWidget" />

    <ProgressBar
        android:id="@+id/pb_loading"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:indeterminate="true"
        android:visibility="gone" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- People section -->
            <LinearLayout
                android:id="@+id/section_people"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="PEOPLE"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_secondary"
                    android:letterSpacing="0.08"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="6dp"
                    android:background="@color/bg_card" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_users"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:background="@color/bg_card" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:background="@color/bg_screen" />

            </LinearLayout>

            <!-- Hubs section -->
            <LinearLayout
                android:id="@+id/section_hubs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="HUBS"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_secondary"
                    android:letterSpacing="0.08"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="6dp"
                    android:background="@color/bg_card" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_hubs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:background="@color/bg_card" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:background="@color/bg_screen" />

            </LinearLayout>

            <!-- Posts section -->
            <LinearLayout
                android:id="@+id/section_posts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="POSTS"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_secondary"
                    android:letterSpacing="0.08"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="6dp"
                    android:background="@color/bg_card" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_posts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:background="@color/bg_card" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:background="@color/bg_screen" />

            </LinearLayout>

            <!-- Challenges section -->
            <LinearLayout
                android:id="@+id/section_challenges"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="CHALLENGES"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_secondary"
                    android:letterSpacing="0.08"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="6dp"
                    android:background="@color/bg_card" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_challenges"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:background="@color/bg_card" />

            </LinearLayout>

            <!-- Empty state -->
            <TextView
                android:id="@+id/tv_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No results found"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:padding="48dp"
                android:visibility="gone" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
