<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_screen">

    <!-- Top bar: title + Search + Create -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="@color/bg_card"
        android:elevation="2dp">

        <TextView
            android:id="@+id/tv_hubs_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Hubs"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <ImageView
            android:id="@+id/btn_search_hubs"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_search"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="6dp"
            android:layout_marginEnd="8dp"
            android:contentDescription="Search hubs"
            android:clickable="true"
            android:focusable="true" />

        <Button
            android:id="@+id/btn_create_hub"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="+ Create"
            android:textSize="13sp"
            android:textStyle="bold"
            android:background="@drawable/btn_primary"
            android:textColor="@color/white"
            android:paddingHorizontal="16dp"
            android:stateListAnimator="@null" />

    </LinearLayout>

    <!-- Inline search bar (hidden by default) -->
    <LinearLayout
        android:id="@+id/search_bar_row"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:background="@color/bg_card"
        android:visibility="gone">

        <EditText
            android:id="@+id/et_hub_search"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:background="@drawable/search_bar_bg"
            android:paddingHorizontal="14dp"
            android:hint="Search hubs..."
            android:textColorHint="@color/text_secondary"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:inputType="text"
            android:imeOptions="actionSearch"
            android:maxLines="1"
            android:singleLine="true" />

        <ImageView
            android:id="@+id/btn_close_search"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:layout_marginStart="4dp"
            android:contentDescription="Close search"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <!-- Tab strip (shown in normal mode) -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tab_layout"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@color/bg_card"
        app:tabTextColor="@color/text_secondary"
        app:tabSelectedTextColor="@color/blue_primary"
        app:tabIndicatorColor="@color/blue_primary"
        app:tabIndicatorHeight="3dp"
        app:tabTextAppearance="@android:style/TextAppearance.Widget.TabWidget"
        app:tabMode="fixed"
        app:tabGravity="fill" />

    <!-- Pager (shown in normal mode) -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/view_pager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Search results (shown in search mode) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_hub_search"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingTop="8dp"
        android:paddingBottom="80dp"
        android:clipToPadding="false"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tv_hub_search_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No hubs found"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone" />

</LinearLayout>
