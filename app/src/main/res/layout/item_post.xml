<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/bg_card">

    <!-- Header: avatar + username + hub chip + timestamp -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:paddingTop="12dp"
        android:paddingBottom="10dp">

        <ImageView
            android:id="@+id/iv_avatar"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="@drawable/ic_avatar_bg"
            android:scaleType="centerCrop"
            android:contentDescription="Avatar"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="10dp">

            <TextView
                android:id="@+id/tv_username"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:id="@+id/tv_hub_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/step_chip_bg"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:textColor="@color/blue_primary"
                android:textSize="11sp"
                android:layout_marginTop="2dp"
                android:visibility="gone"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <TextView
            android:id="@+id/tv_timestamp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/text_secondary" />

    </LinearLayout>

    <!-- Full-width media image (shown only when mediaUrl is non-null) -->
    <ImageView
        android:id="@+id/iv_media"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="200dp"
        android:scaleType="centerCrop"
        android:adjustViewBounds="true"
        android:contentDescription="Post image"
        android:visibility="gone" />

    <!-- Action row: like, comment, share -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="6dp">

        <ImageView
            android:id="@+id/btn_like"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:src="@drawable/ic_heart_outline"
            android:contentDescription="Like"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/tv_likes_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_marginStart="5dp"
            android:layout_marginEnd="14dp" />

        <ImageView
            android:id="@+id/btn_comment"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:src="@drawable/ic_comment"
            android:contentDescription="Comment"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/tv_comments_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_marginStart="5dp"
            android:layout_marginEnd="14dp" />

        <ImageView
            android:id="@+id/btn_share"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:src="@drawable/ic_share"
            android:contentDescription="Share"
            android:clickable="true"
            android:focusable="true" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- Layer 1 — peer micro-validation, only shown on challenge-related posts -->
        <LinearLayout
            android:id="@+id/row_validate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/btn_validate"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_shield_check"
                android:contentDescription="I believe this" />

            <TextView
                android:id="@+id/tv_validate_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginStart="5dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Support row: Mental / Physical / Gift, only shown on announcement posts -->
    <LinearLayout
        android:id="@+id/row_support"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:paddingBottom="10dp"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/btn_support_mental"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/step_chip_bg"
            android:padding="8dp"
            android:layout_marginEnd="6dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🧠"
                android:textSize="18sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mental"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/blue_primary"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_support_physical"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/step_chip_bg"
            android:padding="8dp"
            android:layout_marginEnd="6dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💪"
                android:textSize="18sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Physical"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/blue_primary"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_support_gift"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/step_chip_bg"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎁"
                android:textSize="18sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gift"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/blue_primary"
                android:layout_marginTop="2dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Caption: @username + content -->
    <TextView
        android:id="@+id/tv_caption"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="12dp"
        android:paddingBottom="12dp"
        android:textSize="13sp"
        android:textColor="@color/text_primary"
        android:lineSpacingMultiplier="1.3" />

    <!-- Bottom divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider" />

</LinearLayout>
