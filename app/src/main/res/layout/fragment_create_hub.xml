<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_screen">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        android:background="@color/bg_card"
        android:elevation="2dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_back_arrow"
            android:padding="8dp"
            android:contentDescription="Back"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Create Hub"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginStart="4dp" />

        <Button
            android:id="@+id/btn_create"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Create"
            android:textSize="13sp"
            android:textStyle="bold"
            android:background="@drawable/btn_primary"
            android:textColor="@color/white"
            android:paddingHorizontal="20dp"
            android:stateListAnimator="@null"
            android:enabled="false"
            android:alpha="0.5" />

    </LinearLayout>

    <!-- Form -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Cover image -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cover Image"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="8dp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:layout_marginBottom="20dp"
                android:background="@color/bg_card"
                android:clickable="true"
                android:focusable="true"
                android:id="@+id/layout_cover_picker"
                android:foreground="?attr/selectableItemBackground">

                <ImageView
                    android:id="@+id/iv_cover_preview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    android:contentDescription="Hub cover image" />

                <LinearLayout
                    android:id="@+id/layout_cover_placeholder"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@android:drawable/ic_menu_camera"
                        android:contentDescription="Add cover"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tap to add cover image"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary" />
                </LinearLayout>

            </FrameLayout>

            <!-- Hub name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hub Name *"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="6dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                style="@style/HubRiseTextInput">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="e.g. Android Developers"
                    android:inputType="textCapSentences"
                    android:maxLength="50" />

            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:id="@+id/tv_name_count"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="0 / 50"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:gravity="end"
                android:layout_marginBottom="20dp" />

            <!-- Description -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Description"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="6dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                style="@style/HubRiseTextInput">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="What is this hub about?"
                    android:inputType="textMultiLine|textCapSentences"
                    android:minLines="3"
                    android:gravity="top"
                    android:maxLength="300" />

            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:id="@+id/tv_desc_count"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="0 / 300"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:gravity="end"
                android:layout_marginBottom="24dp" />

            <!-- Privacy -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Privacy"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="10dp" />

            <RadioGroup
                android:id="@+id/rg_privacy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="32dp">

                <RadioButton
                    android:id="@+id/rb_public"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Public"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/radio_privacy_text"
                    android:checked="true"
                    android:button="@null"
                    android:background="@drawable/btn_radio_privacy"
                    android:gravity="center"
                    android:layout_marginEnd="8dp" />

                <RadioButton
                    android:id="@+id/rb_private"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Private"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/radio_privacy_text"
                    android:button="@null"
                    android:background="@drawable/btn_radio_privacy"
                    android:gravity="center" />

            </RadioGroup>

            <!-- Error text -->
            <TextView
                android:id="@+id/tv_error"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="@color/error_red"
                android:gravity="center"
                android:visibility="gone"
                android:layout_marginBottom="12dp" />

            <!-- Loading -->
            <ProgressBar
                android:id="@+id/pb_creating"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center_horizontal"
                android:visibility="gone" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>
