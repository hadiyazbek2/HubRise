<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_screen"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="32dp">

        <!-- Top bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/social_btn_bg"
                android:padding="10dp"
                android:src="@drawable/ic_back_arrow"
                android:contentDescription="Back" />

            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3 of 3"
                android:textColor="@color/blue_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:background="@drawable/step_chip_bg"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Almost there!"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="4dp"
            android:layout_marginTop="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add a photo and short bio"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="4dp" />

        <ProgressBar
            android:id="@+id/pb_progress"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="5dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="28dp"
            android:max="3"
            android:progress="3"
            android:progressDrawable="@drawable/progress_bar_blue" />

        <!-- Profile picture card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/bg_card"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center">

                <!-- Avatar with camera badge -->
                <FrameLayout
                    android:layout_width="110dp"
                    android:layout_height="110dp"
                    android:layout_marginBottom="16dp">

                    <ImageView
                        android:id="@+id/iv_profile_picture"
                        android:layout_width="110dp"
                        android:layout_height="110dp"
                        android:background="@drawable/ic_avatar_bg"
                        android:scaleType="centerCrop"
                        android:contentDescription="Profile picture" />

                    <ImageView
                        android:id="@+id/iv_add_photo"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="bottom|end"
                        android:background="@drawable/ic_camera_bg"
                        android:src="@android:drawable/ic_menu_camera"
                        android:padding="6dp"
                        android:contentDescription="Add photo" />
                </FrameLayout>

                <Button
                    android:id="@+id/btn_pick_photo"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:background="@drawable/btn_outline"
                    android:text="Choose Photo"
                    android:textColor="@color/blue_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="24dp"
                    android:stateListAnimator="@null"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/btn_skip_photo"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:background="@drawable/btn_ghost"
                    android:text="Skip for now"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:paddingHorizontal="16dp"
                    android:stateListAnimator="@null" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Bio card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/bg_card"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Short bio"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Optional – max 160 characters"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="12dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_bio"
                    style="@style/HubRiseTextInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="What are you working towards?"
                    android:layout_marginBottom="4dp"
                    app:counterEnabled="true"
                    app:counterMaxLength="160">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_bio"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textMultiLine|textCapSentences"
                        android:gravity="top|start"
                        android:minLines="3"
                        android:paddingVertical="12dp"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:id="@+id/tv_bio_error"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:textColor="@color/error_red"
                    android:textSize="12sp"
                    android:visibility="gone" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Error banner -->
        <TextView
            android:id="@+id/tv_error"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/error_banner_bg"
            android:gravity="center"
            android:padding="12dp"
            android:textColor="@color/error_red"
            android:textSize="13sp"
            android:visibility="gone" />

        <!-- Complete button -->
        <Button
            android:id="@+id/btn_complete"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/btn_primary"
            android:text="Complete Sign Up"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:stateListAnimator="@null"
            android:layout_marginBottom="8dp" />

        <ProgressBar
            android:id="@+id/pb_loading"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
