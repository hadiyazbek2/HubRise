<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="16dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <!-- Circle with hub initial -->
    <TextView
        android:id="@+id/tv_hub_initial"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:background="@drawable/hub_initial_bg"
        android:gravity="center"
        android:textSize="17sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:text="H" />

    <!-- Hub info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <TextView
            android:id="@+id/tv_hub_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="Hub Name" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="2dp">

            <TextView
                android:id="@+id/tv_hub_members"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:text="0 members" />

            <TextView
                android:id="@+id/tv_hub_privacy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/blue_primary"
                android:textStyle="bold"
                android:text=" · Private"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

    <!-- Checkmark for currently selected -->
    <ImageView
        android:id="@+id/iv_selected_check"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@android:drawable/checkbox_on_background"
        android:contentDescription="Selected"
        android:visibility="gone" />

</LinearLayout>
